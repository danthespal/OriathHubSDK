<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Makes this sample build standalone: it registers the local folder that holds the
    OriathHub.Sdk.<version>.nupkg so NuGet can resolve the PackageReference.

    The value below points at the in-repo feed (Sdk/local-nuget) so the sample restores even with
    a cold NuGet cache. IMPORTANT: the path must exist — NuGet treats a missing local source as a
    hard error (NU1301) and aborts the whole restore, so don't point this at a folder you haven't
    created. If you copy this sample out of the repo to use as a plugin template, change the value
    to the folder where you saved the .nupkg, e.g. value="C:\oriathhub-sdk". nuget.org is inherited.
  -->
  <packageSources>
    <add key="oriathhub-local" value="..\..\local-nuget" />
  </packageSources>
</configuration>
