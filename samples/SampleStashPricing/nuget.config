<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    This sample is laid out exactly like a real, Marketplace-ready plugin repository: the
    OriathHub.Sdk NuGet package is committed under SDK/, and this nuget.config registers that
    folder as the only OriathHub source. The Plugins Marketplace clones a plugin repo with no
    access to the OriathHub source tree or its feed, so the package must travel with the repo.

    <clear /> drops any inherited feeds so the build does not silently depend on a parent
    nuget.config; nuget.org is re-added so the SDK's third-party dependencies still resolve.

    Plugin authors: copy OriathHub.Sdk.<version>.nupkg into SDK/ and commit it, then add
    `!SDK/*.nupkg` to your .gitignore if it contains a broad *.nupkg rule.
  -->
  <packageSources>
    <clear />
    <add key="oriathhub-sdk" value="SDK" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
